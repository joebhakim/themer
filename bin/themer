#!/usr/bin/env python3
"""themer -- centralized theme manager with live preview."""

import sys
from pathlib import Path

# Add the repo root to sys.path so `import themer` works
repo_root = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(repo_root.parent))

from themer.main import main

sys.exit(main() or 0)
